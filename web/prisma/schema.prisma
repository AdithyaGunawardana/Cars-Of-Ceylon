generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  REJECTED
}

enum EventType {
  CREATED
  OWNERSHIP_CHANGE
  SERVICE
  ACCIDENT
  MODIFICATION
  INSPECTION
  NOTE
}

enum VehicleVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  passwordHash   String?
  image          String?
  profile        Json?
  role           UserRole  @default(USER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  vehicles       Vehicle[]
  events         VehicleEvent[]
  photos         VehiclePhoto[]
  reportsCreated Report[]  @relation("ReportCreator")
  reportsHandled Report[]  @relation("ReportModerator")
  followers      Follow[]  @relation("Followee")
  following      Follow[]  @relation("Follower")
}

model Vehicle {
  id                String            @id @default(cuid())
  uniqueIdentifier  String            @unique
  licensePlate      String?           @unique
  manufacturer      String
  model             String
  year              Int
  description       String?
  attributes        Json?
  visibility        VehicleVisibility @default(PUBLIC)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  createdByUserId   String

  createdBy         User              @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  events            VehicleEvent[]
  photos            VehiclePhoto[]
  reports           Report[]

  @@index([manufacturer, model, year])
  @@index([createdAt])
}

model VehicleEvent {
  id           String    @id @default(cuid())
  vehicleId    String
  userId       String
  type         EventType
  title        String
  details      String?
  occurredAt   DateTime?
  sourceUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([vehicleId, createdAt])
  @@index([userId])
}

model VehiclePhoto {
  id           String    @id @default(cuid())
  vehicleId    String
  userId       String
  storageKey   String
  url          String
  caption      String?
  createdAt    DateTime  @default(now())

  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([vehicleId, createdAt])
}

model Follow {
  followerId   String
  followeeId   String
  createdAt    DateTime @default(now())

  follower     User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee     User     @relation("Followee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@id([followerId, followeeId])
  @@index([followeeId])
}

model Report {
  id            String       @id @default(cuid())
  vehicleId      String
  createdById    String
  moderatedById  String?
  reason         String
  status         ReportStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  vehicle        Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdBy      User         @relation("ReportCreator", fields: [createdById], references: [id], onDelete: Restrict)
  moderatedBy    User?        @relation("ReportModerator", fields: [moderatedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

model Account {
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
